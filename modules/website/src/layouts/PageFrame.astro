---
// PageFrame.astro: the site frame for every marketing page.
// A masthead with the logo wordmark and primary nav, a main column, and a footer.
// Theme (light/dark) is resolved before paint by the inline script in <head>.
import {SITE} from '../consts';
import {currentVersion} from '../data/release';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  description?: string;
  /** Active nav label, for highlighting. */
  active?: 'overview' | 'security' | 'download' | 'compare' | 'docs';
}
const {
  title = SITE.title,
  description = SITE.description,
  active = 'overview',
} = Astro.props;

const nav = [
  {label: 'Overview', href: '/', key: 'overview'},
  {label: 'Security', href: '/security', key: 'security'},
  {label: 'Compare', href: '/compare', key: 'compare'},
  {label: 'Download', href: '/download', key: 'download'},
  {label: 'Docs', href: SITE.docs, key: 'docs'},
] as const;

import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // Resolve the theme before first paint to avoid a flash. Honors a stored
      // choice, otherwise follows the system preference.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.dataset.theme = t;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="masthead">
      <div class="shell shell--wide masthead__bar">
        <a class="wordmark" href="/" aria-label={`${SITE.name} home`}>
          <Logo width={160} height={39} />
        </a>
        <div class="masthead__right">
          <nav class="nav" aria-label="Primary">
            {nav.map((item) => (
              <a
                href={item.href}
                class:list={['nav__link', { 'is-active': item.key === active }]}
              >
                {item.label}
              </a>
            ))}
          </nav>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
            <svg class="icon icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="icon icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="shell shell--wide footer__inner">
        <div class="footer__brand">
          <Logo width={120} height={29} />
        </div>
        <nav class="footer__nav" aria-label="Footer">
          <a href={SITE.repo}>GitHub</a>
          <a href={SITE.docs}>Documentation</a>
          <a href="/security">Security</a>
          <a href={SITE.licenseUrl}>License</a>
        </nav>
        <p class="footer__note">Built by the team behind JProfiler.</p>
        {currentVersion !== 'dev' && (
          <p class="footer__version">v{currentVersion}</p>
        )}
      </div>
    </footer>

    <style>
      .skip {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.5rem 0.75rem;
        z-index: 100;
      }
      .skip:focus {
        left: 0;
      }
      .masthead {
        position: relative;
        z-index: 2;
        border-bottom: 1px solid var(--rule-strong);
      }
      .masthead__bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        padding-block: var(--space-4);
      }
      .wordmark {
        display: inline-flex;
        align-items: center;
        color: var(--ink);
        text-decoration: none;
      }
      .wordmark .logo-svg {
        display: block;
      }
      .masthead__right {
        display: flex;
        align-items: center;
        gap: var(--space-5);
      }
      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
      }
      .nav__link {
        font-family: var(--font-mono);
        font-size: var(--step--1);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
        text-decoration: none;
        padding-block: 0.25rem;
        border-bottom: 1px solid transparent;
      }
      .nav__link:hover {
        color: var(--ink);
        border-bottom-color: var(--rule-strong);
      }
      .nav__link.is-active {
        color: var(--brand);
        border-bottom-color: var(--brand);
      }
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        padding: 0;
        border: 1px solid var(--rule-strong);
        border-radius: var(--radius-pill);
        background: transparent;
        color: var(--ink-soft);
        cursor: pointer;
        transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
      }
      .theme-toggle:hover {
        color: var(--ink);
        border-color: var(--ink-muted);
        background: var(--paper-sunk);
      }
      .theme-toggle .icon--sun {
        display: none;
      }
      :root[data-theme="dark"] .theme-toggle .icon--moon {
        display: none;
      }
      :root[data-theme="dark"] .theme-toggle .icon--sun {
        display: inline-flex;
      }
      .footer {
        margin-top: var(--space-8);
        border-top: 1px solid var(--rule-strong);
        background: var(--paper-sunk);
      }
      .footer__inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-4) var(--space-6);
        padding-block: var(--space-6);
      }
      .footer__brand {
        display: inline-flex;
        align-items: center;
      }
      .footer__brand .logo-svg {
        display: block;
      }
      .footer__nav {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
        font-size: var(--step--1);
      }
      .footer__nav a {
        color: var(--ink-soft);
      }
      .footer__note {
        flex-basis: 100%;
        margin: 0;
        color: var(--ink-muted);
        font-size: var(--step--1);
      }
      .footer__version {
        margin: 0;
        color: var(--ink-muted);
        font-size: var(--step--1);
        font-family: var(--font-mono);
      }
    </style>
    <script is:inline>
      // Toggle button: flip the theme and persist the choice.
      document.getElementById('theme-toggle').addEventListener('click', function () {
        var root = document.documentElement;
        var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        try {
          localStorage.setItem('theme', next);
        } catch (e) {}
      });
    </script>
  </body>
</html>
