---
import PageFrame from '../layouts/PageFrame.astro';
import {SITE} from '../consts';

const facts = [
  {
    k: 'No phone home',
    v: 'Agents connect to your jvmguard server. The server makes no outbound calls. All data stays inside your network.',
  },
  {
    k: 'No JMX port',
    v: 'The agent reads MBeans in process. You do not have to open a JMX connector server on the monitored JVM to inspect or operate on MBeans.',
  },
  {
    k: 'Single H2 file',
    v: 'All persistent data, recorded data and configuration, lives in one embedded H2 database file. There is no external database to operate.',
  },
  {
    k: 'TLS for agents',
    v: 'Agent-to-server traffic can be encrypted and authenticated via TLS.',
  },
  {
    k: 'Three access levels',
    v: 'Admin, Profiler, and Viewer roles partition a single server for separate teams.',
  },
  {
    k: 'Local, LDAP, or SSO',
    v: 'Authentication uses locally configured accounts, LDAP, or SSO, all configurable in the UI.',
  },
];

const collect = [
  'Built-in scalar telemetries like heap, CPU, threads or GC',
  'Scalar telemetries from configured sources',
  'Transactions you explicitly configured',
];

const capture = [
  'A JFR recording, for a bounded duration',
  'A heap dump (HPROF)',
  'A thread dump',
  'A JProfiler snapshot',
];
---

<PageFrame
  active="security"
  title={`Security and data flow - ${SITE.name}`}
  description="What the jvmguard agent does and does not do in your JVM: no default collection, no phone home, no cloud egress, source-available under Apache 2.0."
>
  <section class="shell hero">
    <p class="eyebrow">Security and data flow</p>
    <h1>What jvmguard does inside your JVM</h1>
    <p class="lede">
      This page states what the jvmguard agent collects in your JVM, where it sends that data, and
      what you can check in the source. For a tool that runs in production, that is the first question
      to answer.
    </p>
  </section>

  <section class="shell">
    <div class="rule">
      <span class="rule__no">§ 01</span>
      <span class="rule__label">Architecture</span>
    </div>
    <figure class="arch">
      <img src="/architecture.svg" alt="jvmguard architecture: agents in monitored VMs connect to a server that runs the collector, an embedded H2 database, and the web UI." width="510" height="350" />
      <figcaption class="mono">
        Agents push to your server over an authenticated connection. Users reach the web UI over HTTPS.
        No component talks to a vendor.
      </figcaption>
    </figure>
  </section>

  <section class="shell">
    <div class="rule">
      <span class="rule__no">§ 02</span>
      <span class="rule__label">Collected by default</span>
    </div>
    <p>
      jvmguard records only lightweight data, at low steady-state overhead:
    </p>
    <ul class="ticks">
      {collect.map((c) => (
        <li>{c}</li>
      ))}
    </ul>
  </section>

  <section class="shell">
    <div class="rule">
      <span class="rule__no">§ 03</span>
      <span class="rule__label">Captured on demand</span>
    </div>
    <p>
      Deep artifacts are not collected by default. A capture runs only when a trigger fires, or when
      you start one manually on a single JVM.
    </p>
    <ul class="ticks">
      {capture.map((c) => (
        <li>{c}</li>
      ))}
    </ul>
  </section>

  <section class="shell">
    <div class="rule">
      <span class="rule__no">§ 04</span>
      <span class="rule__label">Operational posture</span>
    </div>
    <div class="grid grid--2">
      {facts.map((f) => (
        <article class="fact">
          <h3>{f.k}</h3>
          <p class="muted">{f.v}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell">
    <div class="rule">
      <span class="rule__no">§ 05</span>
      <span class="rule__label">License and deployment</span>
    </div>
    <div class="panel license">
      <div class="license__item">
        <svg class="license__icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        <p><strong>{SITE.license}.</strong> Sources are available. Read it, build it, and audit it with your own tooling before it touches production.</p>
      </div>
      <div class="license__item">
        <svg class="license__icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <p><strong>Self-hosted.</strong> Runs behind your firewall. Suitable for air-gapped networks. No outbound cloud dependency.</p>
      </div>
      <div class="license__item">
        <svg class="license__icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M3 10h18"/><path d="M8 20h8"/><path d="M12 16v4"/></svg>
        <p><strong>Single server.</strong> The collector, the embedded database, and the web UI run in one process. No separate services to secure.</p>
      </div>
    </div>
  </section>
</PageFrame>

<style>
  .hero {
    padding-top: var(--space-7);
    padding-bottom: var(--space-5);
  }
  .arch {
    margin: 0;
    background: var(--paper-raised);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: var(--space-4);
    text-align: center;
  }
  .arch img {
    display: block;
    width: 100%;
    max-width: 760px;
    height: auto;
    margin-inline: auto;
  }
  /* The diagram is authored light (dark ink). Invert it in dark mode. */
  :root[data-theme="dark"] .arch img {
    filter: invert(0.93) hue-rotate(180deg);
  }
  .arch figcaption {
    margin-top: var(--space-4);
    color: var(--ink-muted);
    font-size: var(--step--1);
    max-width: 60ch;
    margin-inline: auto;
  }
  .ticks {
    list-style: none;
    padding: 0;
    max-width: var(--measure);
  }
  .ticks li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: var(--space-3);
  }
  .ticks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.7em;
    height: 0.7em;
    background: var(--alive);
    border-radius: 50%;
  }
  .fact {
    border-top: 1px solid var(--rule);
    padding-top: var(--space-4);
  }
  .fact h3 {
    margin-top: 0;
    color: var(--brand-deep);
  }
  .license {
    max-width: var(--measure);
  }
  .license__item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }
  .license__item + .license__item {
    margin-top: var(--space-4);
  }
  .license__icon {
    flex-shrink: 0;
    color: var(--brand);
    margin-top: 0.2rem;
  }
  .license__item p {
    margin: 0;
    max-width: none;
  }
</style>
