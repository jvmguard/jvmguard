&lt;p&gt;To continue, please open your browser at&lt;/p&gt;
&lt;p&gt;&lt;b&gt;${installer:localUrl}&lt;/b&gt;&lt;/p&gt;
&lt;/html&gt;</property>
                </serializedBean>
                <visibilityScript>!Util.isWindows() &amp;&amp; !Util.isMacOS()</visibilityScript>
              </formComponent>
              <formComponent name="windows" id="5352" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
