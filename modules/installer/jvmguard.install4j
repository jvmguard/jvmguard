          </screen>
          <screen id="4" beanClass="com.install4j.runtime.beans.screens.InstallationDirectoryScreen">
            <condition>!context.getBooleanVariable("sys.streamlinedInstallation")</condition>
            <actions>
              <group name="Initialize from previous" id="402" beanClass="com.install4j.runtime.beans.groups.ActionGroup">
                <beans>
                  <action id="5" beanClass="com.install4j.runtime.beans.actions.misc.LoadResponseFileAction" multiExec="true">
                    <serializedBean>
                      <property name="excludedVariables" type="array" elementType="string" length="1">
                        <element index="0">sys.installationDir</element>
                      </property>
                    </serializedBean>
                    <condition>context.getVariable("sys.responseFile") == null</condition>
                  </action>
                  <action name="Read properties file" id="323" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction" multiExec="true">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">import com.jvmguard.installer.*;

String[] propertyNames = YamlConfigUtil.yamlJvmGuardSectionToInstallerVariables(new File(context.getResourceDirectory(),"application.yaml"), context);
context.setVariable("jvmguardPropertyNames", propertyNames);

File previousPropertiesFile = context.getDestinationFile("config/application.yaml");
if (previousPropertiesFile.exists()) {
    YamlConfigUtil.yamlJvmGuardSectionToInstallerVariables(previousPropertiesFile, context);
}

File mediaPropertiesFile = new File((String)context.getVariable("sys.mediaDir"), "application.yaml");
if (mediaPropertiesFile.exists()) {
    YamlConfigUtil.yamlJvmGuardSectionToInstallerVariables(mediaPropertiesFile, context);
}

return true;</property>
                        </object>
                      </property>
                    </serializedBean>
                  </action>
                  <action name="Check if configured" id="1494" beanClass="com.install4j.runtime.beans.actions.control.SetVariableAction" multiExec="true">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">String dataDirectory = (String)context.getVariable("dataDirectory");
return new File(dataDirectory).isAbsolute();
</property>
                        </object>
                      </property>
                      <property name="variableName" type="string">wasConfigured</property>
                    </serializedBean>
                  </action>
                  <action name="Init properties" id="1493" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction" multiExec="true">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">if (!context.getBooleanVariable("wasConfigured")) {

    String dataDirectory;
    if (Util.isWindows()) {
        dataDirectory = new File(WinFileSystem.getProgramDataDirectory(), "jvmguard").getPath();
    } else if (Util.hasFullAdminRights()) {
        dataDirectory = "/var/opt/jvmguard";
    } else {
        dataDirectory = new File(context.getInstallationDirectory(), "data").getAbsolutePath();
    }

    context.setVariable("dataDirectory", dataDirectory);
}


return true;</property>
                        </object>
                      </property>
                    </serializedBean>
                  </action>
                </beans>
              </group>
            </actions>
            <formComponents>
              <formComponent id="5402" beanClass="com.install4j.runtime.beans.formcomponents.MultilineLabelComponent" insetBottom="25">
                <serializedBean>
                  <property name="labelText" type="string">${i18n:SelectDirLabel(${compiler:sys.fullName})}</property>
