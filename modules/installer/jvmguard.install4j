                  <action name="localUrl" id="4800" beanClass="com.install4j.runtime.beans.actions.control.SetVariableAction">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">(Boolean.TRUE.equals(context.getVariable("useHttps")) ? "https" : "http") + "://localhost:" + (context.getVariable("httpPort") == null ? "8020": context.getVariable("httpPort")) </property>
                        </object>
                      </property>
                      <property name="variableName" type="string">localUrl</property>
                    </serializedBean>
                  </action>
                  <action name="browserPossible" id="4801" beanClass="com.install4j.runtime.beans.actions.control.SetVariableAction">
