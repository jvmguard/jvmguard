              <screen name="Data directory" id="1488" beanClass="com.install4j.runtime.beans.screens.FormScreen">
                <serializedBean>
                  <property name="subTitle" type="string">Where should jvmguard store its data?</property>
                  <property name="title" type="string">Data Directory</property>
                </serializedBean>
                <formComponents>
                  <formComponent id="1489" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                    <serializedBean>
                      <property name="labelHtml" type="string">&lt;html&gt;jvmguard needs a directory to store its database and log files.

&lt;p&gt;If you install multiple jvmguard
servers on the same computer, each installation has to have its own data directory.
</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="1490" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent id="1492" beanClass="com.install4j.runtime.beans.formcomponents.DirectoryChooserComponent">
                    <serializedBean>
                      <property name="labelText" type="string">Data directory:</property>
                      <property name="variableName" type="string">dataDirectory</property>
                    </serializedBean>
                  </formComponent>
                </formComponents>
              </screen>
              <screen name="Configuration level" id="1992" beanClass="com.install4j.runtime.beans.screens.FormScreen">
