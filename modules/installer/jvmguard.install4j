                  <propertyName>labelText</propertyName>
                </externalParametrizationPropertyNames>
              </formComponent>
              <formComponent id="409" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                <serializedBean>
                  <property name="labelHtml" type="string">&lt;html&gt;Configuration properties of the jvmguard server that cannot be changed at runtime are
contained in the file
&lt;p&gt;
&amp;nbsp;&amp;nbsp;&lt;b&gt;config/application.yaml&lt;/b&gt;
&lt;p&gt;
You can edit that file directly, or use this wizard to change them. </property>
                </serializedBean>
              </formComponent>
            </formComponents>
          </screen>
          <group name="Common configuration" id="412" beanClass="com.install4j.runtime.beans.groups.ScreenGroup">
            <beans>
              <screen name="Web server" id="317" beanClass="com.install4j.runtime.beans.screens.FormScreen" wizardIndexChangeType="step" wizardIndexKey="webServer">
                <serializedBean>
                  <property name="subTitle" type="string">Please configure the bundled web server for the user interface.</property>
                  <property name="title" type="string">Web Server Configuration</property>
                </serializedBean>
                <formComponents>
                  <formComponent id="320" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                    <serializedBean>
                      <property name="labelHtml" type="string">&lt;html&gt;jvmguard collects and consolidates monitoring and profiling data from JVMs and presents them
in a web interface. By default, the web interface is run in the same process as the data
collection server.
&lt;p&gt;
Please configure the web server properties below:</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="321" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent name="Port" id="319" beanClass="com.install4j.runtime.beans.formcomponents.IntegerTextfieldComponent">
                    <serializedBean>
                      <property name="columns" type="int" value="5" />
                      <property name="helpText" type="string">&lt;html&gt;The bundled web server for the jvmguard user interface listens on this port.&lt;br&gt;
The default value is &lt;b&gt;8020&lt;/b&gt;.</property>
                      <property name="labelText" type="string">Web server port:</property>
                      <property name="maximumDigits" type="int" value="5" />
                      <property name="minimumDigits" type="int" value="2" />
                      <property name="variableName" type="string">httpPort</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent name="HTTPS" id="1042" beanClass="com.install4j.runtime.beans.formcomponents.CheckboxComponent" insetTop="10">
                    <serializedBean>
                      <property name="checkboxText" type="string">Use HTTPS</property>
                      <property name="helpText" type="string">&lt;html&gt;Select this option if the above port should use the HTTPS protocol.&lt;br&gt;
If selected, the embedded web server will not be reachable by HTTP.</property>
                      <property name="variableName" type="string">useHttps</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent name="Reverse proxy" id="3692" beanClass="com.install4j.runtime.beans.formcomponents.CheckboxComponent">
                    <serializedBean>
                      <property name="checkboxText" type="string">Reverse proxy</property>
                      <property name="coupledComponentIds">
                        <add type="string">3766</add>
                      </property>
                      <property name="helpText" type="string">&lt;html&gt;Select this option if the web server will be running behind a reverse proxy.&lt;br&gt;
The server will then check the "X-Forwarded-Host" header when creating URLs.</property>
                      <property name="selectionScript">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">formEnvironment.getFormComponentById("3766").setVisible(selected);</property>
                        </object>
                      </property>
                      <property name="variableName" type="string">reverseProxy</property>
                    </serializedBean>
                  </formComponent>
                  <group id="3837" beanClass="com.install4j.runtime.beans.groups.VerticalFormComponentGroup">
                    <beans>
                      <formComponent name="Reverse proxy host" id="3766" beanClass="com.install4j.runtime.beans.formcomponents.TextfieldComponent" insetLeft="30">
                        <serializedBean>
                          <property name="helpText" type="string">&lt;html&gt;If the forwarding headers are missing or incompatible with the web server,&lt;br&gt;
you can set an explicit proxy host. If the proxy uses SSL, include the port,&lt;br&gt;
like in &lt;tt&gt;server.com:443&lt;/tt&gt;. If the value is empty, the web server will try to&lt;br&gt;
determine the proxy host automatically.
</property>
                          <property name="labelText" type="string">Reverse proy host:</property>
                          <property name="variableName" type="string">reverseProxyHost</property>
                        </serializedBean>
                        <visibilityScript>false</visibilityScript>
                      </formComponent>
                    </beans>
                  </group>
                </formComponents>
              </screen>
            </beans>
          </group>
          <group name="Detailed configuration" id="1978" beanClass="com.install4j.runtime.beans.groups.ScreenGroup">
            <serializedBean>
              <property name="conditionExpression">
                <object class="com.install4j.api.beans.ScriptProperty">
                  <property name="value" type="string">Integer configLevel = (Integer)context.getVariable("configLevel");
return configLevel == null || configLevel == 1;</property>
                </object>
              </property>
            </serializedBean>
            <beans>
              <screen name="External Access" id="5807" beanClass="com.install4j.runtime.beans.screens.FormScreen">
                <serializedBean>
                  <property name="subTitle" type="string">Configure external access to the jvmguard server</property>
                  <property name="title" type="string">External Access</property>
                </serializedBean>
                <formComponents>
                  <formComponent id="5808" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                    <serializedBean>
                      <property name="labelHtml" type="string">The jvmguard server can expose external access interfaces on the web server port:
&lt;ul&gt;
&lt;li&gt;&lt;b&gt;REST API&lt;/b&gt; at the &lt;tt&gt;/api&lt;/tt&gt; path — programmatic read access to monitoring data&lt;/li&gt;
&lt;li&gt;&lt;b&gt;MCP server&lt;/b&gt; at the &lt;tt&gt;/mcp&lt;/tt&gt; path — for AI assistants like Claude Code and Cursor&lt;/li&gt;
&lt;/ul&gt;
Both use the protocol (HTTP or HTTPS) that is configured for the web server and require API-key authentication.</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="5809" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent id="5811" beanClass="com.install4j.runtime.beans.formcomponents.CheckboxComponent">
                    <serializedBean>
                      <property name="checkboxText" type="string">Enable REST API</property>
                      <property name="initiallySelected" type="boolean" value="true" />
                      <property name="variableName" type="string">restApiEnabled</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="5915" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent id="5916" beanClass="com.install4j.runtime.beans.formcomponents.CheckboxComponent">
                    <serializedBean>
                      <property name="checkboxText" type="string">Enable MCP server</property>
                      <property name="initiallySelected" type="boolean" value="true" />
                      <property name="variableName" type="string">mcpEnabled</property>
                    </serializedBean>
                  </formComponent>
                </formComponents>
              </screen>
              <screen name="SSL" id="1038" beanClass="com.install4j.runtime.beans.screens.FormScreen" wizardIndexChangeType="step" wizardIndexKey="ssl">
                <serializedBean>
                  <property name="subTitle" type="string">Please configure options for authenticating and encrypting connections?</property>
                  <property name="title" type="string">Authentication and Encryption</property>
                </serializedBean>
                <formComponents>
                  <formComponent id="1039" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                    <serializedBean>
                      <property name="labelHtml" type="string">If the communication between VMs and the jvmguard server should be
authenticated and encrypted, select the check box below.
&lt;p&gt;
A certificate file
&lt;b&gt;ssl/agent.ks&lt;/b&gt; will be created when jvmguard is started the next time.
That file has to be placed next to the jvmguard.jar on remote machines in order
to allow communication with the jvmguard server. The agent archives downloaded from the
jvmguard UI already contain the correct certificate file.

</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="1040" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent id="1041" beanClass="com.install4j.runtime.beans.formcomponents.CheckboxComponent">
                    <serializedBean>
                      <property name="checkboxText" type="string">Use SSL for VM connections</property>
                      <property name="variableName" type="string">vmUseSsl</property>
                    </serializedBean>
                  </formComponent>
                </formComponents>
              </screen>
              <screen name="Monitored JVMs" id="548" beanClass="com.install4j.runtime.beans.screens.FormScreen" wizardIndexChangeType="step" wizardIndexKey="monitoredJVMs">
                <serializedBean>
                  <property name="subTitle" type="string">Please configure how monitored JVMs connect to the jvmguard server.</property>
                  <property name="title" type="string">Monitored JVM Options</property>
                </serializedBean>
                <formComponents>
                  <formComponent id="549" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                    <serializedBean>
                      <property name="labelHtml" type="string">&lt;html&gt;The monitored JVMs connect to the jvmguard server on a dedicated port.
&lt;p&gt;
If you are running two jvmguard servers on the same machine or if there is a conflict with another
application, you can change that port below:
</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="550" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent id="551" beanClass="com.install4j.runtime.beans.formcomponents.IntegerTextfieldComponent">
                    <serializedBean>
                      <property name="columns" type="int" value="5" />
                      <property name="helpText" type="string">&lt;html&gt;The port on which the monitored JVMs connect to the jvmguard server.&lt;br&gt;
The default value is &lt;b&gt;8847&lt;/b&gt;.</property>
                      <property name="labelText" type="string">JVM port:</property>
                      <property name="maximumDigits" type="int" value="5" />
                      <property name="minimumDigits" type="int" value="2" />
                      <property name="variableName" type="string">vmPort</property>
                    </serializedBean>
                  </formComponent>
                </formComponents>
              </screen>
            </beans>
          </group>
