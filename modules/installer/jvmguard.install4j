!context.isUnattended() &amp;&amp; !context.isConsole() &amp;&amp;
!context.getBooleanVariable("jvmguard.noService") &amp;&amp; !context.getBooleanVariable("noPrivileges")</property>
                        </object>
                      </property>
                      <property name="variableName" type="string">browserPossible</property>
