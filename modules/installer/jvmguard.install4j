                  </property>
                  <property name="iconSource" type="enum" class="com.install4j.runtime.beans.actions.desktop.IconSource" value="CUSTOM" />
                  <property name="itemName" type="string">${compiler:sys.fullName} ${compiler:sys.version}</property>
                </serializedBean>
              </action>
              <group name="Update properties from default" id="401" beanClass="com.install4j.runtime.beans.groups.ActionGroup">
                <beans>
                  <action name="jvmguardTempFile" id="5148" beanClass="com.install4j.runtime.beans.actions.control.SetVariableAction">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">File file = File.createTempFile("jvmguard", ".yaml");
                   file.deleteOnExit();
                   return file.getAbsolutePath();</property>
                        </object>
                      </property>
                      <property name="variableName" type="string">jvmguardTempFile</property>
                    </serializedBean>
                  </action>
                  <action name="Copy default config file to working dir" id="398" beanClass="com.install4j.runtime.beans.actions.files.CopyFileAction" actionElevationType="elevated">
                    <serializedBean>
                      <property name="destinationFile">
                        <object class="java.io.File">
                          <string>${installer:jvmguardTempFile}</string>
                        </object>
                      </property>
                      <property name="files" type="array" class="java.io.File" length="1">
                        <element index="0">
                          <object class="java.io.File">
                            <string>resources/application.yaml-default</string>
                          </object>
                        </element>
                      </property>
                      <property name="overwriteMode" type="enum" class="com.install4j.api.context.OverwriteMode" value="ALWAYS" />
                    </serializedBean>
                  </action>
                  <action name="Merge properties into config file" id="399" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction" actionElevationType="elevated">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">import com.jvmguard.installer.*;

Properties oldProperties = YamlConfigUtil.readJvmGuardSection(context.getDestinationFile("config/application.yaml"));

File propertiesFile = new File((String)context.getVariable("jvmguardTempFile"));
YamlConfigUtil.mergeJvmGuardSectionYaml(propertiesFile, true, context, oldProperties);

return true;</property>
                        </object>
                      </property>
                    </serializedBean>
                  </action>
                  <action name="Overwrite actual config file" id="400" beanClass="com.install4j.runtime.beans.actions.files.CopyFileAction" actionElevationType="elevated">
                    <serializedBean>
                      <property name="destinationFile">
                        <object class="java.io.File">
                          <string>config/application.yaml</string>
                        </object>
                      </property>
                      <property name="files" type="array" class="java.io.File" length="1">
                        <element index="0">
                          <object class="java.io.File">
                            <string>${installer:jvmguardTempFile}</string>
                          </object>
                        </element>
                      </property>
                      <property name="overwriteMode" type="enum" class="com.install4j.api.context.OverwriteMode" value="ALWAYS" />
                      <property name="uninstallMode" type="enum" class="com.install4j.api.context.UninstallMode" value="IF_CREATED_BUT_NOT_FOR_UPDATE" />
                    </serializedBean>
                  </action>
                  <action id="5366" beanClass="com.install4j.runtime.beans.actions.files.DeleteFileAction" actionElevationType="elevated">
                    <serializedBean>
                      <property name="backupForRollback" type="boolean" value="false" />
                      <property name="files" type="array" class="java.io.File" length="1">
                        <element index="0">
                          <object class="java.io.File">
                            <string>${installer:jvmguardTempFile}</string>
                          </object>
                        </element>
                      </property>
                    </serializedBean>
                  </action>
                </beans>
              </group>
