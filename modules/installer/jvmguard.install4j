              <group name="Copy external config files" id="2945" beanClass="com.install4j.runtime.beans.groups.ActionGroup">
                <beans>
                  <action name="Create data directory" id="2949" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction" actionElevationType="elevated" failureStrategy="quit" errorMessage="The data directory could not be created">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">File dataDir = new File((String)context.getVariable("dataDirectory"));
if (!dataDir.exists() &amp;&amp; !dataDir.mkdirs()) {
    Util.logError(null, "Data directory " + dataDir + " could not be created");
    return false;
}

new File(dataDir, "ssl").mkdir();

return true;
</property>
                        </object>
                      </property>
                    </serializedBean>
                  </action>
