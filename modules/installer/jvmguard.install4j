                  <property name="subTitle" type="string">Do you want to configure advanced options?</property>
                  <property name="title" type="string">Advanced Options</property>
                </serializedBean>
                <formComponents>
                  <formComponent id="1993" beanClass="com.install4j.runtime.beans.formcomponents.MultilineHtmlLabelComponent">
                    <serializedBean>
                      <property name="labelHtml" type="string">&lt;html&gt;All essential configuration steps have been completed.
&lt;p&gt;
There are some advanced configuration options that can now be adjusted.
The advanced configuration is contained in the file &lt;tt&gt;config/application.yaml&lt;/tt&gt; and can be
visually edited with the &lt;b&gt;configure&lt;/b&gt; executable at any time.</property>
                    </serializedBean>
                  </formComponent>
                  <formComponent id="1997" beanClass="com.install4j.runtime.beans.formcomponents.SpacerComponent" />
                  <formComponent id="1996" beanClass="com.install4j.runtime.beans.formcomponents.RadiobuttonsComponent">
                    <serializedBean>
                      <property name="radioButtonLabels" type="array" elementType="string" length="2">
