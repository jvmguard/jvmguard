                  <property name="failIfNotObtainedMac" type="boolean" value="false" />
                  <property name="obtainIfNormalWin" type="boolean" value="true" />
                </serializedBean>
                <condition>(!Util.isMacOS() || Util.isMacosInstaller()) &amp;&amp; !context.getBooleanVariable("noPrivileges")
 </condition>
              </action>
              <action id="5913" beanClass="com.install4j.runtime.beans.actions.control.SetInstallationDirectoryAction" actionElevationType="none" />
              <action name="Register response variables" id="1788" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction">
                <serializedBean>
                  <property name="script">
                    <object class="com.install4j.api.beans.ScriptProperty">
                      <property name="value" type="string">context.registerResponseFileVariable("dataDirectory");
context.registerResponseFileVariable("jvmguard.noService");
return true;</property>
                    </object>
                  </property>
                </serializedBean>
              </action>
              <action name="Test adjustments" id="2182" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction">
                <serializedBean>
                  <property name="script">
                    <object class="com.install4j.api.beans.ScriptProperty">
                      <property name="value" type="string">context.getFileSetByName("Test").setSelected(context.getBooleanVariable("noPrivileges"));
if (context.getBooleanVariable("noPrivileges")) {
    context.setVariable("sys.adminRights", false);
}
return true;</property>
                    </object>
                  </property>
                </serializedBean>
              </action>
              <action name="Select platform files" id="5365" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction">
                <serializedBean>
                  <property name="script">
                    <object class="com.install4j.api.beans.ScriptProperty">
                      <property name="value" type="string">context.getFileSetByName("Windows").setSelected(Util.isWindows());
return true;</property>
                    </object>
                  </property>
                </serializedBean>
              </action>
            </actions>
          </screen>
