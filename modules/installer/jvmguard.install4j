          <screen name="Banner with header at the top" id="5351" beanClass="com.install4j.runtime.beans.screens.FormScreen" styleId="5883" finishScreen="true">
            <serializedBean>
              <property name="title" type="string">Installation completed</property>
            </serializedBean>
            <actions>
              <group id="4975" beanClass="com.install4j.runtime.beans.groups.ActionGroup">
                <serializedBean>
                  <property name="conditionExpression">
                    <object class="com.install4j.api.beans.ScriptProperty">
                      <property name="value" type="string">context.getBooleanVariable("browserPossible") &amp;&amp; context.getBooleanVariable("browserSelected")
</property>
                    </object>
                  </property>
                </serializedBean>
                <beans>
                  <action id="4976" beanClass="com.install4j.runtime.beans.actions.control.SetProgressAction" actionElevationType="none">
                    <serializedBean>
                      <property name="progressChangeType" type="enum" class="com.install4j.runtime.beans.actions.control.ProgressChangeType" value="SET_INDETERMINATE" />
                    </serializedBean>
                  </action>
                  <action id="4977" beanClass="com.install4j.runtime.beans.actions.control.SetMessageAction" actionElevationType="none">
                    <serializedBean>
                      <property name="statusMessage" type="string">Waiting for jvmguard server</property>
                      <property name="useStatus" type="boolean" value="true" />
                    </serializedBean>
                  </action>
                  <action id="4803" beanClass="com.install4j.runtime.beans.actions.control.RunScriptAction">
                    <serializedBean>
                      <property name="script">
                        <object class="com.install4j.api.beans.ScriptProperty">
                          <property name="value" type="string">import java.net.*;
import javax.net.ssl.*;

URL url = URI.create((String)context.getVariable("localUrl")).toURL();

long startTime = System.currentTimeMillis();
long endTime = startTime + 60 * 1000;

boolean success = false;
while (!success &amp;&amp; System.currentTimeMillis() &lt; endTime) {
    try {
        HttpURLConnection connection = (HttpURLConnection)url.openConnection();
        connection.setConnectTimeout(2000);
        connection.setReadTimeout(5000);
        int responseCode = connection.getResponseCode();
        if (responseCode == HttpURLConnection.HTTP_OK) {
            success = true;
        }
    } catch (SSLHandshakeException e) {
            success = true;
    } catch (IOException ignored) {
        // try again
    }
    if (!success) {
        Thread.sleep(1000);
    }
}
if (success) {
    Util.showUrl(url);
} else {
    Util.showWarningMessage("The jvmguard server could not be reached. Please check if the service has been started.");
}
return true;</property>
                        </object>
                      </property>
                    </serializedBean>
                  </action>
                </beans>
              </group>
            </actions>
            <formComponents>
              <formComponent id="5646" beanClass="com.install4j.runtime.beans.formcomponents.MultilineLabelComponent" useExternalParametrization="true" externalParametrizationName="Header" externalParametrizationMode="include">
                <serializedBean>
                  <property name="hideIfBlank" type="boolean" value="true" />
