  <launchers>
    <launcher name="jvmguard Service" id="70">
      <executable name="jvmguard_service" executableDir="bin" stderrFile="${installer:sys.tempDir}/jvmguard_error.log" executableMode="service" workingDirectory=".." dpiAware="false" />
      <java mainClass="com.jvmguard.server.ServerMain" vmParameters="-Djava.awt.headless=true" preferredVM="server">
